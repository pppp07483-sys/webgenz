generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  userId       Int           @unique
  email        String        @unique
  name         String?
  password     String?
  googleId     String?       @unique
  avatar       String?
  phone        String?
  coins        Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  websites     Website[]
}

model Transaction {
  id            String    @id @default(cuid())
  userId        String
  type          String
  coinAmount    Int
  priceAmount   Int?
  paymentMethod String?
  paymentStatus String    @default("PENDING")
  paymentRef    String?
  qrisUrl       String?
  expiredAt     DateTime?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id])
}

model Website {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  prompt      String
  status      String   @default("PROCESSING")
  coinCost    Int      @default(1)
  htmlContent String?
  cssContent  String?
  jsContent   String?
  previewUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}
